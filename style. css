body {
  font-family: Arial, sans-serif;
  margin: 0;
  background: #f2f7f2;
  color: #333;
}

header {
  background: #2e8b57;
  color: white;
  text-align: center;
  padding: 30px;
}

h1 {
  margin: 0;
}

section {
  padding: 20px;
  margin: 20px;
  background: white;
  border-radius: 10px;
}

h2 {
  color: #2e8b57;
}

ul {
  list-style: none;
  padding: 0;
}

ul li {
  padding: 5px 0;
}

footer {
  text-align: center;
  padding: 15px;
  background: #2e8b57;
  color: white;
}
